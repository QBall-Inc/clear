{
  "name": "@qball-inc/clear",
  "version": "1.0.2",
  "description": "Context Layered Engineering for Agentic Resources - Persistent memory and intelligent context management for Claude Code sessions",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "validate": "npm run typecheck && npm run lint",
    "test": "jest",
    "test:logged": "jest --reporters=./tests/reporters/log-reporter.cjs --silent",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:plan": "jest tests/infrastructure/plan",
    "test:workpackage": "jest tests/infrastructure/workpackage",
    "test:sync": "jest tests/infrastructure/sync",
    "test:hooks": "jest tests/infrastructure/hooks",
    "test:skills": "jest tests/infrastructure/skill-system",
    "test:config": "jest tests/infrastructure/config",
    "test:templates": "jest tests/infrastructure/templates",
    "test:context": "jest tests/infrastructure/context",
    "test:knowledge": "jest tests/infrastructure/knowledge",
    "test:unit": "jest --testPathPattern='(parser|validator|types|storage|loader|generator|executor|schema|defaults|engine)\\.test\\.ts$'",
    "test:integration": "jest --testPathPattern='(registry|manager|integration|orchestrator)\\.test\\.ts$'",
    "test:e2e": "jest --testPathPattern='(e2e|cli)\\.test\\.ts$'",
    "test:quick": "jest --testPathPattern='(parser|types|validator)\\.test\\.ts$' --maxWorkers=4",
    "test:slow": "jest --testPathPattern='(e2e|lifecycle|integration)\\.test\\.ts$'",
    "test:changed": "jest --onlyChanged",
    "collect-metrics": "ts-node metrics/collect-metrics.ts",
    "auto-metrics": "ts-node metrics/auto-collect-metrics.ts"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "anthropic",
    "claude",
    "context-management",
    "session-tracking",
    "knowledge-base",
    "knowledge-graph",
    "workpackage",
    "automation",
    "handoff",
    "memory",
    "planning",
    "ai-coding-assistant",
    "ai-agents",
    "llm-tools",
    "code-intelligence"
  ],
  "author": "Ashay Kubal <https://ashaykubal.com>",
  "homepage": "https://github.com/QBall-Inc",
  "repository": {
    "type": "git",
    "url": "https://github.com/QBall-Inc/clear.git"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "12.5.0",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.2.0",
    "yaml": "^2.9.0"
  }
}
